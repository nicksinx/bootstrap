{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bootstrap.local/schemas/profile.schema.json",
  "title": "Profile",
  "description": "Launcher profile that supplies defaults and overlays for project bootstrap.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "profile_version", "name"],
  "properties": {
    "schema_version": { "type": "integer", "minimum": 1 },
    "profile_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "name": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "extends": { "type": "string" },
    "defaults": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "default_branch": { "type": "string" },
        "github": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "visibility": { "enum": ["private", "public"] },
            "create_labels": { "type": "boolean" },
            "create_templates": { "type": "boolean" }
          }
        },
        "mcp": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean" },
            "transport": { "enum": ["stdio", "http"] },
            "auth_profile": {
              "enum": ["none", "local-token", "mtls", "oauth"]
            },
            "token_source": { "enum": ["env", "keychain"] }
          }
        },
        "okf": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean" },
            "bundle_path": { "type": "string" },
            "profile": { "type": "string" },
            "continuous_improvement_path": { "type": "string" }
          }
        }
      }
    },
    "files": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "include": {
          "type": "array",
          "items": { "type": "string" }
        },
        "exclude": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "compat_mode": { "enum": ["strict", "warn", "legacy"] }
  }
}
