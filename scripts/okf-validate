#!/usr/bin/env python3
import datetime as dt
import re
import sys
from pathlib import Path

RESERVED = {"index.md", "project.md", "log.md"}
CRITICAL_TYPES = {
    "Project",
    "Requirement",
    "Feature",
    "Architecture",
    "Decision",
    "Workflow",
    "Runbook",
    "Agent Rule",
    "Agent Skill",
    "Tool Adapter",
    "Risk",
    "Test Case",
    "Test Evidence",
    "Release",
    "Handoff",
    "Improvement",
    "Lesson Learned",
    "Retrospective",
}
SECRET_PATTERNS = [
    re.compile(r"-----BEGIN [A-Z ]*PRIVATE KEY-----"),
    re.compile(r"\bAKIA[0-9A-Z]{16}\b"),
    re.compile(r"\bghp_[A-Za-z0-9_]{20,}\b"),
    re.compile(r"\bxox[baprs]-[A-Za-z0-9-]{20,}\b"),
    re.compile(r"\bsk-[A-Za-z0-9]{20,}\b"),
    re.compile(r"(?i)\b(password|api[_-]?key|token|secret)\s*[:=]\s*['\"]?[A-Za-z0-9_./+=-]{12,}"),
]
LINK_RE = re.compile(r"\[[^\]]+\]\(([^)]+)\)")


def split_frontmatter(text):
    if not text.startswith("---\n"):
        return None, text
    end = text.find("\n---", 4)
    if end == -1:
        return None, text
    return text[4:end], text[end + 4 :]


def parse_simple_yaml(frontmatter):
    data = {}
    for line in frontmatter.splitlines():
        if not line.strip() or line.lstrip().startswith("#"):
            continue
        if ":" not in line:
            continue
        key, value = line.split(":", 1)
        data[key.strip()] = value.strip().strip('"').strip("'")
    return data


def valid_iso8601(value):
    try:
        dt.datetime.fromisoformat(value.replace("Z", "+00:00"))
        return True
    except ValueError:
        return False


def find_root():
    current = Path.cwd()
    for candidate in [current, *current.parents]:
        if (candidate / ".okf").is_dir():
            return candidate
    return current


def check_links(root, path, text):
    warnings = []
    for raw in LINK_RE.findall(text):
        target = raw.split("#", 1)[0].strip()
        if not target or target.startswith(("http://", "https://", "mailto:")):
            continue
        target_path = (path.parent / target).resolve()
        if not target_path.exists():
            alt_path = (root / target).resolve()
            if not alt_path.exists():
                warnings.append(f"{path}: broken link warning: {raw}")
    return warnings


def main():
    root = find_root()
    okf = root / ".okf"
    failures = []
    warnings = []

    if not okf.is_dir():
        print("FAIL: .okf directory not found")
        return 1

    for path in sorted(okf.rglob("*.md")):
        rel = path.relative_to(root)
        text = path.read_text(encoding="utf-8")

        for pattern in SECRET_PATTERNS:
            if pattern.search(text):
                failures.append(f"{rel}: likely secret detected")
                break

        frontmatter, _ = split_frontmatter(text)
        is_reserved = path.name in RESERVED and path.parent == okf
        if frontmatter is None:
            if is_reserved:
                warnings.append(f"{rel}: reserved file has no frontmatter")
            else:
                failures.append(f"{rel}: missing YAML frontmatter")
            continue

        data = parse_simple_yaml(frontmatter)
        concept_type = data.get("type", "")
        if not is_reserved and not concept_type:
            failures.append(f"{rel}: missing non-empty type")

        timestamp = data.get("timestamp")
        if timestamp and not valid_iso8601(timestamp):
            failures.append(f"{rel}: timestamp is not ISO 8601: {timestamp}")

        if concept_type in CRITICAL_TYPES and not data.get("sensitivity"):
            warnings.append(f"{rel}: project-critical concept missing sensitivity")

        if concept_type in CRITICAL_TYPES and not data.get("verification_status"):
            warnings.append(f"{rel}: project-critical concept missing verification_status")

        if concept_type == "Reference" and data.get("status") == "draft":
            if data.get("verification_status") != "unverified":
                failures.append(
                    f"{rel}: draft Reference must have verification_status: unverified"
                )
            if data.get("source_of_truth", "").lower() == "true":
                failures.append(
                    f"{rel}: draft Reference must have source_of_truth: false"
                )

        warnings.extend(check_links(root, path, text))

    for item in warnings:
        print(f"WARN: {item}")
    for item in failures:
        print(f"FAIL: {item}")

    if failures:
        print(f"OKF validation failed: {len(failures)} failure(s), {len(warnings)} warning(s)")
        return 1

    print(f"OKF validation passed: {len(warnings)} warning(s)")
    return 0


if __name__ == "__main__":
    sys.exit(main())
