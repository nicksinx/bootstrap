.PHONY: launch validate-launch github-init backlog-init \
        okf-validate okf-context-pack okf-handoff okf-dispatch-status \
        release-gate test-launch

PROJECT_ID ?= __PROJECT_ID__

launch:
	./scripts/launch_project.sh --name $(PROJECT_ID) --profile default

validate-launch:
	./scripts/validate_launch.sh

test-launch:
	./scripts/validate_launch.sh

okf-validate:
	./scripts/okf-validate

okf-context-pack:
	./scripts/okf-context-pack

okf-handoff:
	@test -n "$(TASK)" || (echo "usage: make okf-handoff TASK=short-task-name"; exit 2)
	./scripts/okf-handoff $(TASK)

okf-dispatch-status:
	./scripts/okf-dispatch status

github-init:
	./scripts/github_init.sh

backlog-init:
	./scripts/backlog_seed.sh

release-gate:
	./scripts/validate_launch.sh --release-gate
